# Local-only mode for UI and browser acceptance. Never enable in production.
CRM_DEMO_MODE=false
APP_URL=https://crm.example.com

# Supabase project used by the deployed CRM.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=one-shot-server-only-key

# One-shot administrator initialization credentials.
# Run `npm run auth:bootstrap-admin`, then remove ADMIN_PASSWORD immediately.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-temporary-password
ADMIN_CHINESE_NAME=系统管理员
ADMIN_ENGLISH_NAME=System Administrator
ADMIN_USERNAME=lumina.admin
ADMIN_ROTATE_PASSWORD=false

# Cloudflare Turnstile. The secret must never use a NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-site-key
TURNSTILE_SECRET_KEY=your-secret-key
TURNSTILE_EXPECTED_HOSTNAME=crm.example.com
