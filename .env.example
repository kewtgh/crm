APP_URL=https://crm.example.com
# Every staff sign-in must be protected by Turnstile. The secret is server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace-with-production-site-key
TURNSTILE_SECRET_KEY=replace-with-production-secret-key
TURNSTILE_EXPECTED_HOSTNAME=crm.example.com

# Supabase project used by the deployed CRM.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key
CRM_WORKSPACE_ID=00000000-0000-4000-8000-000000000001
# Independent HMAC key for account/source login-throttle identifiers.
LOGIN_THROTTLE_HASH_SECRET=replace-with-at-least-32-random-bytes
# Independent HMAC key for signed email-verification state and trusted-device
# tokens. Rotating this key invalidates every remembered device.
TRUSTED_DEVICE_HASH_SECRET=replace-with-a-different-32-byte-random-secret

# Server-side email delivery endpoint. It handles notification outbox messages,
# staff-account-created, calendar-invite, calendar-update, and calendar-cancel
# templates. It must never log temporaryPassword values.
EMAIL_DELIVERY_WEBHOOK_URL=https://mailer.example.com/crm-delivery
EMAIL_DELIVERY_WEBHOOK_TOKEN=replace-with-a-server-only-token
OUTBOX_BATCH_SIZE=20
CALENDAR_DELIVERY_BATCH_SIZE=20
EXPORT_BATCH_SIZE=10
# Hard ceiling for an export job. Jobs fail explicitly instead of silently
# truncating rows, and record expected/exported counts plus a SHA-256 receipt.
EXPORT_MAX_ROWS=250000
REMINDER_BATCH_SIZE=100

# Provider webhook signatures. Each configured provider must use a different
# long, randomly generated server-only secret.
# Webhook and integration workers are optional. They are ignored by the worker
# cycle and readiness checks until their explicit feature flag is true.
WEBHOOKS_ENABLED=false
WEBHOOK_MICROSOFT_365_SECRET=replace-with-a-long-random-secret
WEBHOOK_GOOGLE_CALENDAR_SECRET=replace-with-a-long-random-secret
WEBHOOK_EMAIL_SECRET=replace-with-a-long-random-secret
WEBHOOK_E_SIGNATURE_SECRET=replace-with-a-long-random-secret
WEBHOOK_ACCOUNTING_SECRET=replace-with-a-long-random-secret
WEBHOOK_PAYMENT_SECRET=replace-with-a-long-random-secret
WEBHOOK_PROCESSOR_URL=https://integration-worker.example.com/crm-events
WEBHOOK_PROCESSOR_TOKEN=replace-with-a-server-only-token
WEBHOOK_BATCH_SIZE=20

# Provider-specific sync adapter. It receives a provider, direction and opaque
# cursor, and returns { "nextCursor": "..." } only after the provider confirms
# the sync. OAuth/callback services confirm connections through the
# service-role-only confirm_integration_connection RPC.
INTEGRATION_SYNC_ENABLED=false
INTEGRATION_SYNC_PROCESSOR_URL=https://integration-worker.example.com/crm-sync
INTEGRATION_SYNC_PROCESSOR_TOKEN=replace-with-a-server-only-token
INTEGRATION_SYNC_BATCH_SIZE=10
# Optional stable instance identifier; when omitted each process generates one.
WORKER_ID=

# Optional future AI adapter. v2.2.0 remains rules-first and never sends CRM
# data externally. Setting these only marks the provider as configured; a future
# reviewed adapter must still be explicitly implemented and enabled.
AI_PROVIDER_ENABLED=false
AI_PROVIDER_URL=
AI_PROVIDER_TOKEN=

# One-shot administrator initialization credentials.
# Run `npm run auth:bootstrap-admin`, then remove ADMIN_PASSWORD immediately.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-temporary-password
ADMIN_CHINESE_NAME=系统管理员
ADMIN_ENGLISH_NAME=System Administrator
ADMIN_USERNAME=lumina.admin
ADMIN_ROTATE_PASSWORD=false
