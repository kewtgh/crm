[Unit]
Description=Lumina CRM background worker cycle
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=lumina-crm
Group=lumina-crm
WorkingDirectory=/opt/lumina-crm/current
EnvironmentFile=/etc/lumina-crm/production.env
ExecStart=/usr/bin/node scripts/process-worker-cycle.mjs
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict

[Install]
WantedBy=multi-user.target
