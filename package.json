{
  "name": "lumina-education-crm",
  "version": "1.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev --port 3200",
    "build": "vinext build",
    "start": "vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "auth:bootstrap-admin": "node --env-file=.env.local scripts/bootstrap-admin.mjs",
    "reminders:process": "node --env-file=.env.local scripts/process-reminders.mjs",
    "outbox:process": "node --env-file=.env.local scripts/process-notification-outbox.mjs",
    "calendar-deliveries:process": "node --env-file=.env.local scripts/process-calendar-deliveries.mjs",
    "smoke:phase2": "node --env-file=.env.local scripts/smoke-phase2.mjs",
    "smoke:http-v09": "node --env-file=.env.local scripts/smoke-http-v09.mjs",
    "smoke:http-v10": "node --env-file=.env.local scripts/smoke-http-v10.mjs",
    "smoke:v09": "node --env-file=.env.local scripts/smoke-v09.mjs",
    "smoke:v11": "node --env-file=.env.local scripts/smoke-v11.mjs",
    "exports:process": "node --env-file=.env.local scripts/process-generated-jobs.mjs",
    "webhooks:process": "node --env-file=.env.local scripts/process-webhook-inbox.mjs",
    "integrations:process": "node --env-file=.env.local scripts/process-integration-sync.mjs",
    "env:configure-local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/configure-local-environment.ps1"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "react-server-dom-webpack": "19.2.6",
    "supabase": "^2.109.1",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "wrangler": "4.112.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "type": "module"
}
