model Workspace {
  id          String          @id @default(uuid()) @db.Uuid
  name        String
  slug        String          @unique
  status      WorkspaceStatus @default(ACTIVE)
  timezone    String          @default("Asia/Shanghai")
  defaultCurrency String       @default("CNY") @db.VarChar(3)
  settings    Json?
  createdAt   DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime        @updatedAt @db.Timestamptz(3)
  archivedAt  DateTime?       @db.Timestamptz(3)

  memberships              WorkspaceMembership[]
  teams                    Team[]
  accessRoles              AccessRole[]
  organizations            Organization[]
  organizationUnits        OrganizationUnit[]
  curricula                Curriculum[]
  standardPositions        StandardPosition[]
  people                   Person[]
  personContacts           PersonContactMethod[]
  staffProfiles            SchoolStaffProfile[]
  parentProfiles           ParentProfile[]
  staffAssignments         StaffAssignment[]
  personRelationships      PersonRelationship[]
  households               Household[]
  householdMembers         HouseholdMember[]
  students                 StudentProfile[]
  guardianRelationships    StudentGuardianRelationship[]
  academicCalendars        AcademicCalendar[]
  gradeLevels              GradeLevel[]
  progressionRules         GradeProgressionRule[]
  enrollments              StudentEnrollment[]
  academicSnapshots        StudentAcademicSnapshot[]
  subjectRecords           StudentSubjectRecord[]
  assessmentTypes          AssessmentType[]
  assessmentAttempts       StudentAssessmentAttempt[]
  studentIntents           StudentIntent[]
  targetPreferences        StudentTargetPreference[]
  studentExperiences       StudentExperience[]
  progressionExceptions   StudentProgressionException[]
  progressionEvents       StudentProgressionEvent[]
  pipelines                Pipeline[]
  pipelineStages           PipelineStage[]
  leads                    Lead[]
  leadHistories            LeadStatusHistory[]
  opportunities            Opportunity[]
  opportunityHistories     OpportunityStageHistory[]
  opportunityContacts      OpportunityContactRole[]
  products                 Product[]
  opportunityProducts      OpportunityProduct[]
  contracts                Contract[]
  payments                 Payment[]
  activities               Activity[]
  activityParticipants     ActivityParticipant[]
  tasks                    Task[]
  taskCollaborators        TaskCollaborator[]
  documents                Document[]
  tags                     Tag[]
  organizationTags         OrganizationTag[]
  personTags               PersonTag[]
  householdTags            HouseholdTag[]
  studentTags              StudentTag[]
  leadTags                 LeadTag[]
  opportunityTags          OpportunityTag[]
  importJobs               ImportJob[]
  importSourceFiles        ImportSourceFile[]
  importMappings           ImportMapping[]
  importIssues             ImportRowIssue[]
  importResults            ImportEntityResult[]
  importRollbacks          ImportRollback[]
  reportTemplates          ReportTemplate[]
  reportJobs               ReportJob[]
  aiProviders              AiProvider[]
  aiModels                 AiModel[]
  aiPromptTemplates        AiPromptTemplate[]
  aiRuns                   AiRun[]
  aiEvidence               AiEvidence[]
  savedViews               SavedView[]
  customFieldDefinitions   CustomFieldDefinition[]
  customFieldValues        CustomFieldValue[]
  mergeRecords             EntityMerge[]
  dataQualityIssues        DataQualityIssue[]
  auditLogs                AuditLog[]

  @@map("workspaces")
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  email           String   @unique
  normalizedEmail String   @unique
  displayName     String
  avatarUrl       String?
  isPlatformAdmin Boolean  @default(false)
  lastLoginAt     DateTime? @db.Timestamptz(3)
  createdAt       DateTime @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @db.Timestamptz(3)
  disabledAt      DateTime? @db.Timestamptz(3)

  memberships WorkspaceMembership[]
  auditLogs   AuditLog[] @relation("AuditActor")

  @@map("users")
}

model WorkspaceMembership {
  id             String           @id @default(uuid()) @db.Uuid
  workspaceId    String           @db.Uuid
  userId         String           @db.Uuid
  status         MembershipStatus @default(INVITED)
  systemRole     SystemRole       @default(VIEWER)
  jobTitle       String?
  invitedAt      DateTime?        @db.Timestamptz(3)
  joinedAt       DateTime?        @db.Timestamptz(3)
  lastActiveAt   DateTime?        @db.Timestamptz(3)
  createdAt      DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @db.Timestamptz(3)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  teamMemberships       TeamMembership[]
  roleAssignments       MembershipAccessRole[]
  ownedOrganizations    Organization[] @relation("OrganizationOwner")
  ownedPeople           Person[] @relation("PersonOwner")
  ownedHouseholds       Household[] @relation("HouseholdOwner")
  ownedStudents         StudentProfile[] @relation("StudentOwner")
  ownedLeads            Lead[] @relation("LeadOwner")
  ownedOpportunities    Opportunity[] @relation("OpportunityOwner")
  ownedActivities       Activity[] @relation("ActivityOwner")
  assignedTasks         Task[] @relation("TaskAssignee")
  createdTasks          Task[] @relation("TaskCreator")
  progressionApprovals  StudentProgressionEvent[] @relation("ProgressionApprover")
  createdImportJobs     ImportJob[] @relation("ImportCreator")
  createdReportJobs     ReportJob[] @relation("ReportCreator")
  createdDocuments      Document[] @relation("DocumentCreator")
  requestedExports      ReportJob[] @relation("ReportRequester")
  createdMerges         EntityMerge[] @relation("MergeCreator")
  assignedQualityIssues        DataQualityIssue[] @relation("QualityIssueAssignee")
  relationshipOwnedAssignments StaffAssignment[] @relation("StaffRelationshipOwner")
  leadStatusChanges             LeadStatusHistory[] @relation("LeadStatusChanger")
  opportunityStageChanges       OpportunityStageHistory[] @relation("OpportunityStageChanger")
  taskCollaborations            TaskCollaborator[] @relation("TaskCollaboratorMembership")
  requestedImportRollbacks      ImportRollback[] @relation("ImportRollbackRequester")
  reviewedAiRuns                AiRun[] @relation("AiRunReviewer")
  savedViews                    SavedView[] @relation("SavedViewOwner")
  membershipAuditLogs           AuditLog[] @relation("AuditMembershipActor")

  @@unique([workspaceId, userId])
  @@index([workspaceId, status])
  @@map("workspace_memberships")
}

model Team {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  parentTeamId String?  @db.Uuid
  name        String
  code        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    Team?     @relation("TeamHierarchy", fields: [parentTeamId], references: [id], onDelete: SetNull)
  children  Team[]    @relation("TeamHierarchy")

  memberships  TeamMembership[]
  organizations Organization[]
  people        Person[]
  households    Household[]
  students      StudentProfile[]
  leads         Lead[]
  opportunities Opportunity[]
  tasks         Task[]

  @@unique([workspaceId, name])
  @@index([workspaceId, parentTeamId])
  @@map("teams")
}

model TeamMembership {
  id           String   @id @default(uuid()) @db.Uuid
  teamId       String   @db.Uuid
  membershipId String   @db.Uuid
  isTeamLead   Boolean  @default(false)
  createdAt    DateTime @default(now()) @db.Timestamptz(3)

  team       Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  membership WorkspaceMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([teamId, membershipId])
  @@index([membershipId])
  @@map("team_memberships")
}

model AccessRole {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  name        String
  description String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  permissions AccessRolePermission[]
  memberships MembershipAccessRole[]

  @@unique([workspaceId, name])
  @@map("access_roles")
}

model Permission {
  id          String @id @default(uuid()) @db.Uuid
  code        String @unique
  name        String
  description String?

  roles AccessRolePermission[]

  @@map("permissions")
}

model AccessRolePermission {
  id           String @id @default(uuid()) @db.Uuid
  accessRoleId String @db.Uuid
  permissionId String @db.Uuid

  accessRole AccessRole @relation(fields: [accessRoleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([accessRoleId, permissionId])
  @@map("access_role_permissions")
}

model MembershipAccessRole {
  id           String @id @default(uuid()) @db.Uuid
  membershipId String @db.Uuid
  accessRoleId String @db.Uuid

  membership WorkspaceMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  accessRole AccessRole          @relation(fields: [accessRoleId], references: [id], onDelete: Cascade)

  @@unique([membershipId, accessRoleId])
  @@map("membership_access_roles")
}

model Organization {
  id                         String             @id @default(uuid()) @db.Uuid
  workspaceId                String             @db.Uuid
  parentOrganizationId       String?            @db.Uuid
  ownerMembershipId          String?            @db.Uuid
  teamId                     String?            @db.Uuid
  type                       OrganizationType
  status                     OrganizationStatus @default(PROSPECT)
  schoolType                 SchoolType?
  legalName                  String?
  displayName                String
  englishName                String?
  normalizedName             String
  aliases                    String[]           @default([])
  countryCode                String?            @db.VarChar(2)
  administrativeArea         String?
  city                       String?
  district                   String?
  addressLine                String?
  postalCode                 String?
  websiteUrl                 String?
  websiteDomain              String?
  phone                      String?
  establishedYear            Int?
  studentCount               Int?
  internationalStudentCount Int?
  graduationStudentCount     Int?
  relationshipTier           String?
  relationshipHealthScore    Int?
  dataCompletenessScore      Int?
  lastContactAt              DateTime?          @db.Timestamptz(3)
  nextFollowUpAt             DateTime?          @db.Timestamptz(3)
  source                     String?
  notes                      String?
  customFields               Json?
  visibility                 VisibilityScope    @default(OWNER_TEAM)
  createdAt                  DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt                  DateTime           @updatedAt @db.Timestamptz(3)
  deletedAt                  DateTime?          @db.Timestamptz(3)

  workspace Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    Organization?         @relation("OrganizationHierarchy", fields: [parentOrganizationId], references: [id], onDelete: SetNull)
  children  Organization[]        @relation("OrganizationHierarchy")
  owner     WorkspaceMembership?  @relation("OrganizationOwner", fields: [ownerMembershipId], references: [id], onDelete: SetNull)
  team      Team?                 @relation(fields: [teamId], references: [id], onDelete: SetNull)

  units                 OrganizationUnit[]
  curricula             OrganizationCurriculum[]
  staffAssignments      StaffAssignment[]
  staffProfilesAsEmployer SchoolStaffProfile[]
  parentProfilesAsEmployer ParentProfile[]
  personRelationships   PersonRelationship[]
  academicCalendars     AcademicCalendar[]
  enrollments           StudentEnrollment[]
  leads                 Lead[]
  opportunities         Opportunity[]
  activities            Activity[]
  tasks                 Task[]
  documents             Document[]
  tags                  OrganizationTag[]
  contracts             Contract[]
  dataQualityIssues     DataQualityIssue[]

  @@index([workspaceId, type, status])
  @@index([workspaceId, normalizedName])
  @@index([workspaceId, city])
  @@index([workspaceId, websiteDomain])
  @@index([ownerMembershipId])
  @@index([teamId])
  @@map("organizations")
}

model OrganizationUnit {
  id          String               @id @default(uuid()) @db.Uuid
  workspaceId String               @db.Uuid
  organizationId String            @db.Uuid
  parentUnitId String?              @db.Uuid
  type        OrganizationUnitType
  name        String
  code        String?
  description String?
  sortOrder   Int                  @default(0)
  isActive    Boolean              @default(true)
  effectiveFrom DateTime?          @db.Date
  effectiveTo DateTime?            @db.Date
  createdAt   DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime             @updatedAt @db.Timestamptz(3)
  deletedAt   DateTime?            @db.Timestamptz(3)

  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       OrganizationUnit? @relation("OrganizationUnitHierarchy", fields: [parentUnitId], references: [id], onDelete: SetNull)
  children     OrganizationUnit[] @relation("OrganizationUnitHierarchy")

  staffAssignments StaffAssignment[]
  enrollments      StudentEnrollment[]

  @@unique([organizationId, parentUnitId, name])
  @@index([workspaceId, organizationId, parentUnitId])
  @@map("organization_units")
}

model Curriculum {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  workspace       Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organizations   OrganizationCurriculum[]
  gradeLevels     GradeLevel[]
  progressionRules GradeProgressionRule[]
  enrollments     StudentEnrollment[]

  @@unique([workspaceId, code])
  @@unique([workspaceId, name])
  @@map("curricula")
}

model OrganizationCurriculum {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  curriculumId   String   @db.Uuid
  isPrimary      Boolean  @default(false)
  startedAt      DateTime? @db.Date
  endedAt        DateTime? @db.Date
  createdAt      DateTime @default(now()) @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  curriculum   Curriculum   @relation(fields: [curriculumId], references: [id], onDelete: Restrict)

  @@unique([organizationId, curriculumId, startedAt])
  @@index([curriculumId])
  @@map("organization_curricula")
}

model StandardPosition {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  code        String
  name        String
  category    String?
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  staffAssignments StaffAssignment[]

  @@unique([workspaceId, code])
  @@unique([workspaceId, name])
  @@map("standard_positions")
}

model Person {
  id                  String       @id @default(uuid()) @db.Uuid
  workspaceId         String       @db.Uuid
  ownerMembershipId   String?      @db.Uuid
